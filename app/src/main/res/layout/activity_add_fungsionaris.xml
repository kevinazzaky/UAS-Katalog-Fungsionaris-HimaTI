<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    tools:context=".presentation.login.add.AddFungsionarisViewModel">

    <TextView
        android:id="@+id/tv_title_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Tambah Fungsionaris"
        android:textColor="@color/warm_gold_accent"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_add_form"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/warm_gold_accent"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title_add">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/et_add_nama"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:backgroundTint="@color/warm_gold_accent"
                android:hint="Nama Lengkap"
                android:inputType="textPersonName"
                android:textColor="@android:color/white"
                android:textColorHint="#88FFFFFF"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_add_nim"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/warm_gold_accent"
                android:hint="NIM (Minimal 8 Angka)"
                android:inputType="number"
                android:textColor="@android:color/white"
                android:textColorHint="#88FFFFFF"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_add_tahun"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/warm_gold_accent"
                android:hint="Tahun Angkatan (Misal: 2023)"
                android:inputType="number"
                android:textColor="@android:color/white"
                android:textColorHint="#88FFFFFF"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Pilih Divisi"
                app:hintTextColor="@color/warm_gold_accent"
                app:boxStrokeColor="@color/warm_gold_accent">

                <AutoCompleteTextView
                    android:id="@+id/spinner_add_divisi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@android:color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btn_simpan_data"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/warm_gold_accent"
                android:text="SIMPAN DATA"
                android:textColor="@color/black_bg"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>